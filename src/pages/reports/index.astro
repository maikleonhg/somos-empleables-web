---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const reports = await getCollection("reports");
// Ordenar por fecha descending
reports.sort(
    (a: CollectionEntry<"reports">, b: CollectionEntry<"reports">) =>
        new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout
    title="Reportes del Cliente | Somos Empleables"
    description="Acceso exclusivo a reportes estratégicos para nuestros clientes."
>
    <main class="max-w-7xl mx-auto px-6 py-24 sm:py-32">
        <header class="max-w-3xl mb-16" data-aos="fade-right">
            <h1
                class="text-5xl font-extrabold text-slate-900 tracking-tight sm:text-6xl mb-6"
            >
                Reportes <span class="text-blue-600 block sm:inline"
                    >Estratégicos</span
                >
            </h1>
            <p class="text-xl text-slate-600 leading-relaxed mb-8">
                Acceso exclusivo a análisis detallados y seguimiento de
                proyectos para nuestros socios colaboradores.
            </p>
        </header>

        <div class="grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
            {
                reports.map((report) => (
                    <a
                        href={`/reports/${report.slug}`}
                        class="group block p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl hover:border-blue-200 transition-all duration-300 relative overflow-hidden"
                        data-aos="fade-up"
                    >
                        <div class="absolute inset-0 bg-linear-to-br from-blue-50/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />

                        <div class="flex items-center gap-2 mb-6 pointer-events-none">
                            <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full">
                                {report.data.client}
                            </span>
                            <span class="text-slate-400 text-xs">
                                {report.data.date
                                    .split("-")
                                    .reverse()
                                    .join("/")}
                            </span>
                        </div>

                        <h2 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-blue-700 transition-colors">
                            {report.data.title}
                        </h2>
                        <p class="text-slate-600 mb-6 text-sm line-clamp-2">
                            {report.data.description}
                        </p>

                        <div class="flex items-center text-blue-600 font-semibold text-sm group-hover:gap-2 transition-all">
                            <span>Ver reporte completo</span>
                            <span class="opacity-0 group-hover:opacity-100 group-hover:block transition-all transform translate-x-2 group-hover:translate-x-0">
                                →
                            </span>
                        </div>
                    </a>
                ))
            }
        </div>

        {
            reports.length === 0 && (
                <div
                    class="text-center py-20 bg-slate-50 rounded-4xl border border-dashed border-slate-200"
                    data-aos="zoom-in"
                >
                    <p class="text-slate-400 italic text-lg">
                        Aún no hay reportes publicados. ¡Vuelve pronto!
                    </p>
                </div>
            )
        }
    </main>
</Layout>
