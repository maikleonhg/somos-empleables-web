---
const instagramUrl = "https://www.instagram.com/somosempleables/";
---

<nav
    class="fixed top-0 w-full left-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100 transition-all"
>
    <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
        <a
            href="/"
            class="text-2xl font-bold tracking-tight text-slate-900 flex items-center gap-2"
        >
            <span>Somos<span class="text-blue-600">Empleables</span></span>
        </a>

        <!-- Desktop Menu -->
        <div class="hidden md:flex gap-8">
            <a
                href="/#sobre-nosotros"
                class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors"
                >Nosotros</a
            >
            <a
                href="/#servicios"
                class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors"
                >Servicios</a
            >
            <a
                href="/#testimonios"
                class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors"
                >Testimonios</a
            >
            <a
                href="/blog"
                class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors"
                >Blog</a
            >
        </div>

        <!-- Desktop Button -->
        <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden md:block bg-slate-900 text-white px-5 py-2.5 rounded-full text-sm font-medium hover:bg-slate-800 transition-colors cursor-pointer shadow-lg shadow-slate-900/10"
        >
            Empezar Ahora
        </a>

        <!-- Mobile Burger Button -->
        <button
            id="mobile-menu-btn"
            class="md:hidden text-slate-900 p-2 focus:outline-none"
            aria-label="Menu"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
            </svg>
        </button>
    </div>

    <!-- Mobile Menu Dropdown -->
    <div
        id="mobile-menu"
        class="hidden md:hidden bg-white border-b border-slate-100 px-6 py-6 absolute w-full left-0 top-full shadow-lg flex-col gap-4"
    >
        <a
            href="/#sobre-nosotros"
            class="text-base font-medium text-slate-600 hover:text-blue-600 py-2 block border-b border-slate-50"
            >Nosotros</a
        >
        <a
            href="/#servicios"
            class="text-base font-medium text-slate-600 hover:text-blue-600 py-2 block border-b border-slate-50"
            >Servicios</a
        >
        <a
            href="/#testimonios"
            class="text-base font-medium text-slate-600 hover:text-blue-600 py-2 block border-b border-slate-50"
            >Testimonios</a
        >
        <a
            href="/blog"
            class="text-base font-medium text-slate-600 hover:text-blue-600 py-2 block border-b border-slate-50"
            >Blog</a
        >
        <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-blue-600 text-white text-center py-3 rounded-xl font-bold mt-2 shadow-lg shadow-blue-600/20 block"
        >
            Empezar Ahora
        </a>
    </div>
</nav>

<script is:inline>
    // Self-executing function to avoid global namespace pollution and ensure it runs
    (function initNavbar() {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");

        if (btn && menu) {
            // Toggle Menu
            btn.onclick = (e) => {
                e.stopPropagation(); // Prevent immediate closing if clicking button
                menu.classList.toggle("hidden");
                menu.classList.toggle("flex");
            };

            // Close when clicking links
            const links = menu.querySelectorAll("a");
            links.forEach((link) => {
                link.onclick = () => {
                    menu.classList.add("hidden");
                    menu.classList.remove("flex");
                };
            });

            // Close when clicking outside
            document.onclick = (e) => {
                if (
                    !menu.contains(e.target) &&
                    !btn.contains(e.target) &&
                    !menu.classList.contains("hidden")
                ) {
                    menu.classList.add("hidden");
                    menu.classList.remove("flex");
                }
            };
        }
    })();
</script>
